{
  "name": "@studypop/desktop",
  "version": "1.1.0",
  "private": true,
  "description": "StudyPop desktop application",
  "author": "StudyPop",
  "main": "src/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "electron .",
    "pack": "electron-builder --dir --publish never",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win --publish never"
  },
  "devDependencies": {
    "electron": "42.3.3",
    "electron-builder": "26.15.2"
  },
  "build": {
    "appId": "com.studypop.desktop",
    "productName": "StudyPop",
    "asar": true,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "icon": "../ios/StudyPop/Resources/Assets.xcassets/AppIcon.appiconset/AppIcon-1024.png",
    "win": {
      "icon": "../ios/StudyPop/Resources/Assets.xcassets/AppIcon.appiconset/AppIcon-1024.png",
      "target": [
        "nsis"
      ],
      "artifactName": "StudyPop-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
