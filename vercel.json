{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60,
      "includeFiles": "{index.html,camera.html,src/**,public/**,scripts/**}"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/:path*",
      "destination": "/api/index.mjs"
    }
  ]
}
